#include <iostream>
#include <vector>
#include <omp.h>
#include <climits>

using namespace std;

// -------- Minimum Reduction --------
void minReduction(vector<int>& arr) {

    int n = arr.size();
    int minValue = INT_MAX;

    #pragma omp parallel for reduction(min:minValue)
    for (int i = 0; i < n; i++) {

        if (arr[i] < minValue) {
            minValue = arr[i];
        }
    }

    cout << "Minimum Value : " << minValue << endl;
}

// -------- Maximum Reduction --------
void maxReduction(vector<int>& arr) {

    int n = arr.size();
    int maxValue = INT_MIN;

    #pragma omp parallel for reduction(max:maxValue)
    for (int i = 0; i < n; i++) {

        if (arr[i] > maxValue) {
            maxValue = arr[i];
        }
    }

    cout << "Maximum Value : " << maxValue << endl;
}

// -------- Sum Reduction --------
void sumReduction(vector<int>& arr) {

    int n = arr.size();
    int sum = 0;

    #pragma omp parallel for reduction(+:sum)
    for (int i = 0; i < n; i++) {

        sum += arr[i];
    }

    cout << "Sum : " << sum << endl;
}

// -------- Average Reduction --------
void avgReduction(vector<int>& arr) {

    int n = arr.size();
    int sum = 0;

    #pragma omp parallel for reduction(+:sum)
    for (int i = 0; i < n; i++) {

        sum += arr[i];
    }

    double average = (double)sum / n;

    cout << "Average : " << average << endl;
}

// -------- Main Function --------
int main() {

    vector<int> arr;

    arr.push_back(5);
    arr.push_back(9);
    arr.push_back(6);
    arr.push_back(10);
    arr.push_back(7);
    arr.push_back(4);
    arr.push_back(3);
    arr.push_back(2);
    arr.push_back(1);

    minReduction(arr);
    maxReduction(arr);
    sumReduction(arr);
    avgReduction(arr);

    return 0;
}
