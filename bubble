#include<iostream>
#include<vector>
#include<omp.h>
using namespace std;

void sequentialBubbleSort(vector<int>& a){
        int n = a.size();
        int swapped;
        for(int i =0; i<n-1; i++){
	    swapped = 0;
            for(int j = 0; j< n-i-1; j++){
                if(a[j]>a[j+1]){
                    swap(a[j],a[j+1]);
		    swapped = 1;
                }
            }
	    if(!swapped){
		break;
	    }
        }
}

void parallelBubbleSort(vector<int>& a){
	int n = a.size();
	int swapped;
	
	for(int i =0; i<n-1; i++){
		swapped = 0;
		int first = i%2;
		#pragma omp parallel for shared(a,first)
		for(int j = first; j<n-1; j++){
			if(a[j]>a[j+1]){
				swap(a[j],a[j+1]);
				swapped =1;
			}
		}
		if(!swapped){
			break;
		}
	}
}

int main(){
	int n;
	cout<<"Enter Size: \n";
	cin >>n;
	
	vector<int> a(n), b(n);
	for(int i =0; i<n; i++){
		cin>>a[i];
		b[i] = a[i];
	}
	
	double start = omp_get_wtime();
	sequentialBubbleSort(a);
	double end = omp_get_wtime();

	cout<<"Sorted Array: \n";
	for(int i =0; i<n; i++){
		cout<<a[i]<<" ";
	}
	
	cout<<"time taken for sequential: "<<end-start<<" seconds";

	double starts = omp_get_wtime();
	parallelBubbleSort(a);
	double ends = omp_get_wtime();	
	
	cout<<"Sorted Array: \n";
	for(int i =0; i<n; i++){
		cout<<a[i]<<" ";
	}
	
	cout<<"time taken for parallel: "<<ends-starts<<" seconds";
}

